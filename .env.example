# Copy this file to .env and fill in your values

# Get this from Discord Developer Portal → your app → Bot → Token
DISCORD_TOKEN=

# Right-click a Discord channel → Copy Channel ID (enable Developer Mode first)
# Optional: only needed if you want the bot to auto-post without a command
DISCORD_CHANNEL_ID=

# For run.py / cron usage (no bot process needed)
# Channel Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL
DISCORD_WEBHOOK_URL=

# Optional: enables the ✨ Enrich button in the web UI
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=